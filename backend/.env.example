PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/career_prep_hub
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
GOOGLE_CLIENT_ID=replace_with_google_web_client_id
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LOCK_MINUTES=15

# Email OTP (Gmail App Password)
EMAIL_USER=vishwa11664@gmail.com
EMAIL_PASS=your_gmail_app_password_without_spaces

# Comma-separated list of allowed origins in production
CORS_ORIGINS=http://localhost:5500,http://localhost:3000

# Request body max size
REQUEST_BODY_LIMIT=100kb

# Logger level: error|warn|info|http|verbose|debug|silly
LOG_LEVEL=info

# Optional SMTP config for OTP emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@careerprephub.com
